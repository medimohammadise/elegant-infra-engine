# Recommended for this repository: use the kubeconfig generated by components/kind-cluster.
kubeconfig_path = "../kind-cluster/blitzinfra-kubeconfig"
api_server_host = "myserver"
cluster_name    = "blitzinfra"

observability = {
  namespace = "observability"

  elasticsearch = {
    enabled        = true
    chart_version  = "8.5.1"
    replicas       = 1
    minimum_master = 1
  }

  fluentd = {
    enabled       = true
    chart_version = "0.5.2"
  }

  kibana = {
    enabled       = true
    chart_version = "8.5.1"
    expose_public = true
    node_port     = 32081
    host_port     = 7081
  }

  jaeger = {
    enabled          = true
    chart_version    = "3.4.1"
    expose_public    = true
    query_node_port  = 31686
    query_host_port  = 7068
    collector_memory = "256Mi"
    query_memory     = "256Mi"
  }
}

recreate_revision = ""
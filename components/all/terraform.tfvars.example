ssh_context_host     = "myserver"
ssh_private_key_path = "~/.ssh/id_rsa"
api_server_host      = "myserver"
bootstrap_namespace  = "blitzpay-dev"

registry = {
  network_name   = "registry_net"
  create_network = true
  bind_address   = "0.0.0.0"
  port           = 5000
  ui_bind        = "127.0.0.1"
  ui_port        = 8081
  title          = "Remote Docker Registry"
}

postgres = {
  bind_address = "0.0.0.0"
  port         = 5432
  db_name      = "blitzinfra"
  user         = "blitzinfra"
  password     = "change-me"
  volume_name  = "postgres_data"
}

kubernetes = {
  cluster_name    = "blitzinfra"
  api_server_port = 6443
  worker_count    = 4
  kind_node_image = "kindest/node:v1.30.0@sha256:047357ac0cfea04663786a612ba1eaba9702bef25227a794b52890dd8bcd692e"
}

backstage = {
  enabled       = true
  namespace     = "backstage"
  chart_version = "2.6.3"
  image_tag     = "1.30.2"
  base_url      = "https://myserver:7007"
  expose_public = true
  node_port     = 32007
  host_port     = 7007
}

dashboard = {
  enabled           = false
  namespace         = "kubernetes-dashboard"
  chart_url         = "https://github.com/kubernetes-retired/dashboard/releases/download/kubernetes-dashboard-7.14.0/kubernetes-dashboard-7.14.0.tgz"
  expose_public     = false
  node_port         = 32443
  host_port         = 8443
  create_admin_user = true
  admin_user_name   = "admin-user"
}

recreate_revision = ""


observability = {
  enabled   = true
  namespace = "observability"

  elasticsearch = {
    enabled        = true
    chart_version  = "8.5.1"
    replicas       = 1
    minimum_master = 1
  }

  fluentd = {
    enabled       = true
    chart_version = "0.5.2"
  }

  kibana = {
    enabled       = true
    chart_version = "8.5.1"
    expose_public = false
    node_port     = 32081
    host_port     = 7081
  }

  jaeger = {
    enabled          = true
    chart_version    = "3.4.1"
    expose_public    = false
    query_node_port  = 31686
    query_host_port  = 7068
    collector_memory = "256Mi"
    query_memory     = "256Mi"
  }
}
